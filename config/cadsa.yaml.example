# /etc/cadsa/cadsa.yaml — cadsa configuration
# Copy this file to /etc/cadsa/cadsa.yaml and adjust as needed.
# Install script generates this automatically with secrets filled in.

server:
  host: "127.0.0.1"        # never 0.0.0.0 in production
  port: 3131
  secret_key: ""            # auto-generated on first install (32 bytes hex)
  jwt_private_key_path: "/etc/cadsa/jwt_private.pem"
  jwt_public_key_path: "/etc/cadsa/jwt_public.pem"

caddy:
  # Admin API — used for automatic log discovery (recommended)
  admin_api_url: "http://localhost:2019"
  admin_api_enabled: true

  # Caddyfile path — fallback if admin API is unreachable
  # Leave empty for automatic detection from process args or common paths
  caddyfile_path: ""

logs:
  # AUTO-DISCOVERY (default): cadsa reads Caddy Admin API to find log files.
  # Only set manual sources below if auto-discovery fails or is disabled.
  auto_discover: true

  # Manual sources (override or supplement auto-discovery)
  # sources:
  #   - path: "/var/log/caddy/access.log"
  #     format: "json"       # json | auto
  #     label: "global"      # shown in UI for entries with no host field

  # How far back to read on startup (0 = only tail new lines)
  initial_backfill_hours: 24

database:
  analytics_path: "/var/lib/cadsa/analytics.duckdb"
  app_path: "/var/lib/cadsa/app.sqlite"
  retention_days: 90
  aggregation_retention_days: 365

geoip:
  enabled: true
  db_path: "/var/lib/cadsa/GeoLite2-City.mmdb"
  auto_update: true

security:
  rate_limit_threshold: 300
  error_rate_threshold: 0.20
  slow_request_threshold_ms: 2000

alerts:
  email:
    enabled: false
    smtp_host: ""
    smtp_port: 587
    smtp_user: ""
    smtp_password: ""
    from: ""
    to: []
  webhook:
    enabled: false
    url: ""
    secret: ""

threat_intel:
  abuseipdb:
    enabled: false
    api_key: ""
    cache_hours: 24
